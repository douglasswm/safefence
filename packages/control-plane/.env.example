# SafeFence Control Plane

# PostgreSQL connection string (required)
DATABASE_URL=postgres://user:password@localhost:5432/safefence

# Redis connection URL
REDIS_URL=redis://localhost:6379

# JWT secret for instance token signing (change in production!)
JWT_SECRET=safefence-dev-secret-change-in-production

# HTTP port
PORT=3100

# Allowed CORS origin (dashboard URL)
CORS_ORIGIN=http://localhost:3200
