# SafeFence Control Plane

# PostgreSQL connection string (required)
DATABASE_URL=postgres://user:password@localhost:5432/safefence

# Redis connection URL
REDIS_URL=redis://localhost:6379

# JWT secret for instance token signing (REQUIRED — server will not start without this)
JWT_SECRET=

# HTTP port
PORT=3100

# Allowed CORS origin (dashboard URL)
CORS_ORIGIN=http://localhost:3200

# Optional: Require this secret in X-Bootstrap-Secret header to create new organizations.
# Leave unset to allow unauthenticated org creation (suitable for development).
# BOOTSTRAP_SECRET=
