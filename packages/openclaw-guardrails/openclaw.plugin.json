{
  "id": "openclaw-guardrails",
  "name": "openclaw-guardrails",
  "version": "0.6.5",
  "description": "Deterministic local guardrails for OpenClaw hooks",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "mode": {
        "type": "string",
        "enum": ["enforce", "audit"],
        "default": "enforce"
      },
      "failClosed": {
        "type": "boolean",
        "default": true
      },
      "workspaceRoot": {
        "type": "string"
      },
      "principal": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "requireContext": { "type": "boolean", "default": true },
          "ownerIds": {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          },
          "adminIds": {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          },
          "failUnknownInGroup": { "type": "boolean", "default": true }
        }
      },
      "authorization": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "defaultEffect": {
            "type": "string",
            "enum": ["deny", "allow"],
            "default": "deny"
          },
          "requireMentionInGroups": { "type": "boolean", "default": true },
          "restrictedTools": {
            "type": "array",
            "items": { "type": "string" }
          },
          "restrictedDataClasses": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["internal", "restricted", "secret"]
            }
          },
          "toolAllowByRole": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "owner": { "type": "array", "items": { "type": "string" } },
              "admin": { "type": "array", "items": { "type": "string" } },
              "member": { "type": "array", "items": { "type": "string" } },
              "unknown": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      },
      "approval": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "ttlSeconds": { "type": "number", "default": 300 },
          "requireForTools": {
            "type": "array",
            "items": { "type": "string" }
          },
          "requireForDataClasses": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["restricted", "secret"]
            }
          },
          "ownerQuorum": { "type": "number", "default": 1 },
          "bindToConversation": { "type": "boolean", "default": true },
          "storagePath": { "type": "string" }
        }
      },
      "tenancy": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "budgetKeyMode": {
            "type": "string",
            "enum": ["agent", "agent+principal+conversation"],
            "default": "agent+principal+conversation"
          },
          "redactCrossPrincipalOutput": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "outboundGuard": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "systemPromptLeakPatterns": {
            "type": "array",
            "items": { "type": "string" },
            "default": [
              "security policy (immutable)",
              "immutable security policy",
              "# system prompt",
              "begin system prompt",
              "here is my system prompt",
              "here are my instructions",
              ".openclaw",
              "heartbeat.md",
              "bootstrap.md",
              "identity.md"
            ]
          },
          "injectedFileNames": {
            "type": "array",
            "items": { "type": "string" },
            "default": [
              "agents.md",
              "soul.md",
              "bootstrap.md",
              "heartbeat.md",
              "identity.md",
              "tools.md",
              "user.md",
              ".openclaw/",
              ".openclaw"
            ]
          }
        }
      },
      "rollout": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "stage": {
            "type": "string",
            "enum": [
              "stage_a_audit",
              "stage_b_high_risk_enforce",
              "stage_c_full_enforce"
            ],
            "default": "stage_c_full_enforce"
          },
          "highRiskTools": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "monitoring": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "falsePositiveThresholdPct": { "type": "number", "default": 3 },
          "consecutiveDaysForTuning": { "type": "number", "default": 2 }
        }
      },
      "audit": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": false },
          "sinkPath": { "type": "string" }
        }
      },
      "externalValidation": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": false },
          "endpoint": { "type": "string" },
          "timeoutMs": { "type": "number" },
          "validators": {
            "type": "array",
            "items": { "type": "string" }
          },
          "failOpen": { "type": "boolean", "default": false }
        }
      },
      "budgetPersistence": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": false },
          "storagePath": { "type": "string" }
        }
      },
      "notifications": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": false },
          "adminChannelId": { "type": "string" }
        }
      }
    }
  }
}
