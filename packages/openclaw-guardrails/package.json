{
  "name": "@safefence/openclaw-guardrails",
  "version": "0.7.1",
  "description": "Native deterministic guardrails plugin for OpenClaw",
  "openclaw": {
    "extensions": [
      "./dist/plugin/openclaw-extension.js"
    ]
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "preversion": "pnpm test && pnpm run build",
    "version": "bash scripts/sync-version.sh",
    "postversion": "echo '\nRun this to publish via CI:\n  git push origin master --tags'"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "openclaw",
    "guardrails",
    "security",
    "owasp",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/douglasswm/safefence.git",
    "directory": "packages/openclaw-guardrails"
  },
  "publishConfig": {
    "provenance": true
  },
  "license": "MIT",
  "bin": {
    "safefence": "dist/cli/index.js"
  },
  "dependencies": {
    "@safefence/types": "workspace:*"
  },
  "peerDependencies": {
    "better-sqlite3": ">=11.0.0",
    "openclaw": ">=2026.2.25"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.9.0",
    "@vitest/coverage-v8": "^4.0.18",
    "better-sqlite3": "^12.6.2",
    "typescript": "^5.6.3",
    "vitest": "^4.0.18"
  },
  "vitest": {
    "coverage": {
      "provider": "v8",
      "reporter": [
        "text",
        "json-summary",
        "lcov"
      ],
      "include": [
        "src/core/**/*.ts",
        "src/plugin/**/*.ts"
      ],
      "thresholds": {
        "lines": 80,
        "functions": 80,
        "branches": 70,
        "statements": 80
      }
    }
  }
}
