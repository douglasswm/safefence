{
  "name": "@safefence/openclaw-guardrails",
  "version": "0.6.0",
  "description": "Native deterministic guardrails plugin for OpenClaw",
  "openclaw": {
    "extensions": [
      "./dist/plugin/openclaw-extension.js"
    ]
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "openclaw",
    "guardrails",
    "security",
    "owasp",
    "llm"
  ],
  "license": "MIT",
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.8",
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "vitest": {
    "coverage": {
      "provider": "v8",
      "reporter": [
        "text",
        "json-summary",
        "lcov"
      ],
      "include": [
        "src/core/**/*.ts",
        "src/plugin/**/*.ts"
      ],
      "thresholds": {
        "lines": 80,
        "functions": 80,
        "branches": 70,
        "statements": 80
      }
    }
  }
}
