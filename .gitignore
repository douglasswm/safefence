# macOS
.DS_Store

# Node dependencies
node_modules/
**/node_modules/

# Build outputs
dist/
**/dist/
coverage/
**/coverage/
*.tsbuildinfo
.next/
**/.next/

# Next.js auto-generated
next-env.d.ts

# Lockfiles (only root pnpm-lock.yaml is authoritative)
packages/*/pnpm-lock.yaml
package-lock.json
**/package-lock.json
yarn.lock
**/yarn.lock

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# npm cache
.npm-cache/
**/.npm-cache/

# Serena
.serena/

# Environment files (may contain secrets)
.env
.env.local
.env.*.local
.env.production
